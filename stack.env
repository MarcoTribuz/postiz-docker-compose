# =============================================================
# stack.env - variabili stack Postiz per Portainer
# Copia questi valori nella sezione "Environment variables"
# dello stack in Portainer e compila i campi vuoti.
# NON committare questo file con password reali dentro.
# =============================================================

# --- URL pubblici (NO slash finale su MAIN_URL / FRONTEND_URL) ---
MAIN_URL=https://postiz.tuodominio.it
FRONTEND_URL=https://postiz.tuodominio.it
NEXT_PUBLIC_BACKEND_URL=https://postiz.tuodominio.it/api

# --- Secret app ---
# Genera con: openssl rand -hex 32
JWT_SECRET=

# --- DB Postiz ---
POSTIZ_DB_USER=postiz-user
POSTIZ_DB_PASSWORD=
POSTIZ_DB_NAME=postiz-db-local

# --- DB Temporal ---
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=
